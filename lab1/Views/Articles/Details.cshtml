@using System.Security.Claims
@model lab1.Models.Article

@{
    ViewData["Title"] = Model.Title;
    var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
}

<style>
    /* === СТИЛІ ДЛЯ ЗАБЛОКОВАНОГО СТАНУ === */
    .locked-glass-panel {
        position: relative;
        margin-top: 40px;
        padding: 60px 40px;
        text-align: center;
        background: rgba(10, 20, 40, 0.3);
        backdrop-filter: blur(25px) saturate(150%);
        -webkit-backdrop-filter: blur(25px) saturate(150%);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 32px;
        box-shadow: inset 0 2px 10px rgba(255, 255, 255, 0.02), 0 20px 40px rgba(0, 0, 0, 0.4);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }

        /* Декоративний відблиск на фоні */
        .locked-glass-panel::before {
            content: '';
            position: absolute;
            top: -50%;
            left: 50%;
            transform: translateX(-50%);
            width: 60%;
            height: 100%;
            background: radial-gradient(ellipse at top, rgba(100, 170, 255, 0.1), transparent 70%);
            pointer-events: none;
        }

    .lock-icon-wrapper {
        width: 64px;
        height: 64px;
        border-radius: 50%;
        background: rgba(0, 0, 0, 0.4);
        border: 1px solid rgba(255, 255, 255, 0.1);
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 20px;
        color: rgba(255, 255, 255, 0.6);
        box-shadow: inset 0 2px 4px rgba(255,255,255,0.05), 0 10px 20px rgba(0,0,0,0.5);
    }

        .lock-icon-wrapper svg {
            width: 28px;
            height: 28px;
        }

    .locked-title {
        font-size: 1.5rem;
        font-weight: 700;
        color: #fff;
        margin-bottom: 10px;
        letter-spacing: -0.01em;
    }

    .locked-subtitle {
        color: rgba(255, 255, 255, 0.5);
        font-size: 0.95rem;
        max-width: 400px;
        margin-bottom: 30px;
        line-height: 1.5;
    }

    .btn-unlock-glass {
        padding: 14px 32px;
        border-radius: 100px;
        font-size: 0.95rem;
        font-weight: 600;
        text-decoration: none;
        color: #fff;
        background: rgba(10, 60, 160, 0.4);
        border: 1px solid rgba(100, 150, 255, 0.3);
        backdrop-filter: blur(10px);
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2), inset 0 1px 2px rgba(255, 255, 255, 0.1);
    }

        .btn-unlock-glass:hover {
            background: rgba(20, 80, 200, 0.6);
            border-color: rgba(100, 170, 255, 0.6);
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(10, 60, 160, 0.4), inset 0 1px 2px rgba(255, 255, 255, 0.2);
            color: #fff;
        }

    .chat-img-attachment {
        cursor: zoom-in;
        transition: transform 0.2s;
    }

        .chat-img-attachment:hover {
            transform: scale(1.02);
            box-shadow: 0 10px 20px rgba(0, 255, 200, 0.2);
        }

    .lightbox-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background: rgba(10, 15, 30, 0.9);
        backdrop-filter: blur(15px);
        -webkit-backdrop-filter: blur(15px);
        z-index: 10000;
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.3s ease;
    }

        .lightbox-overlay.active {
            opacity: 1;
            pointer-events: auto;
        }

    .lightbox-image {
        max-width: 90%;
        max-height: 90vh;
        border-radius: 20px;
        box-shadow: 0 30px 80px rgba(0,0,0,0.8), 0 0 40px rgba(0, 255, 200, 0.1);
        transform: scale(0.9);
        transition: transform 0.3s cubic-bezier(0.2, 0.8, 0.2, 1);
        object-fit: contain;
    }

    .lightbox-overlay.active .lightbox-image {
        transform: scale(1);
    }

    .lightbox-close {
        position: absolute;
        top: 30px;
        right: 40px;
        color: #fff;
        font-size: 2.5rem;
        cursor: pointer;
        width: 50px;
        height: 50px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(255,255,255,0.1);
        transition: all 0.2s;
    }

        .lightbox-close:hover {
            background: #ff453a;
            color: #fff;
            transform: scale(1.1);
        }

    .reader-container {
        max-width: 800px;
        margin: 0 auto;
        animation: fadeUp 1s cubic-bezier(0.2, 0.8, 0.2, 1);
    }

    .reading-glass {
        background: rgba(30, 30, 35, 0.4);
        backdrop-filter: blur(50px) saturate(100%);
        -webkit-backdrop-filter: blur(50px) saturate(100%);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 40px;
        padding: 60px 80px;
        position: relative;
        overflow: hidden;
        box-shadow: 0 40px 100px rgba(0, 0, 0, 0.5);
    }

    .article-title {
        font-size: 3.5rem;
        font-weight: 800;
        letter-spacing: -0.03em;
        line-height: 1.1;
        color: #fff;
        margin-bottom: 30px;
        background: linear-gradient(180deg, #fff 0%, rgba(255,255,255,0.8) 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .meta-row {
        display: flex;
        align-items: center;
        gap: 24px;
        padding-bottom: 40px;
        margin-bottom: 40px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }

    .meta-item {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .meta-label {
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: rgba(255, 255, 255, 0.3);
        font-weight: 600;
    }

    .meta-value {
        font-size: 0.95rem;
        color: rgba(255, 255, 255, 0.9);
        font-weight: 500;
    }

    .rating-badge {
        background: rgba(255, 214, 10, 0.1);
        color: #FFD60A;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 0.9rem;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 4px;
    }

    .prose-content {
        font-size: 1.25rem;
        line-height: 1.7;
        color: rgba(255, 255, 255, 0.85);
        white-space: pre-wrap;
        margin-bottom: 60px;
    }

    .authors-section {
        margin-top: 60px;
        padding-top: 30px;
        border-top: 1px solid rgba(255, 255, 255, 0.05);
    }

    .author-chip {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: rgba(255, 255, 255, 0.05);
        padding: 8px 16px;
        border-radius: 50px;
        text-decoration: none;
        color: rgba(255, 255, 255, 0.8);
        font-size: 0.9rem;
        transition: all 0.2s;
        border: 1px solid transparent;
    }

        .author-chip:hover {
            background: rgba(255, 255, 255, 0.1);
            color: #fff;
            border-color: rgba(255, 255, 255, 0.1);
        }

    .author-avatar {
        width: 24px;
        height: 24px;
        border-radius: 50%;
        background: rgba(255,255,255,0.1);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.7rem;
        font-weight: 700;
    }

    .rating-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        margin-top: 60px;
        background: rgba(0,0,0,0.2);
        padding: 30px;
        border-radius: 24px;
        border: 1px solid rgba(255,255,255,0.03);
    }

    .rating-title {
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: rgba(255,255,255,0.5);
        margin-bottom: 16px;
        font-weight: 700;
    }

    .stars-wrapper {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
        justify-content: center;
    }

    .star-btn {
        background: transparent;
        border: none;
        cursor: pointer;
        padding: 0;
        color: rgba(255, 255, 255, 0.15);
        transition: all 0.2s cubic-bezier(0.25, 0.8, 0.25, 1);
    }

        .star-btn svg {
            width: 28px; /* Трохи менші, бо їх аж 10 */
            height: 28px;
            transition: transform 0.2s;
        }

        .star-btn.hover-active {
            color: #FFD60A;
            opacity: 0.6;
            transform: scale(1.1);
        }

        .star-btn.active {
            color: #FFD60A;
            drop-shadow: 0 0 10px rgba(255, 214, 10, 0.5);
            transform: scale(1.15);
        }

    .btn-confirm-rating {
        background: rgba(0, 255, 200, 0.1);
        color: #00ffc8;
        border: 1px solid rgba(0, 255, 200, 0.3);
        padding: 10px 28px;
        border-radius: 30px;
        font-size: 0.9rem;
        font-weight: 600;
        margin-top: 20px;
        cursor: pointer;
        transition: all 0.3s;
        display: none;
        box-shadow: 0 5px 15px rgba(0, 255, 200, 0.1);
    }

        .btn-confirm-rating:hover {
            background: #00ffc8;
            color: #0a0f1e;
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(0, 255, 200, 0.25);
        }


    .action-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 60px;
        padding-top: 30px;
        border-top: 1px solid rgba(255, 255, 255, 0.05);
    }

    .btn-back {
        color: rgba(255, 255, 255, 0.4);
        text-decoration: none;
        font-size: 0.95rem;
        transition: color 0.2s;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .btn-back:hover {
            color: #fff;
        }

    .btn-group-actions {
        display: flex;
        gap: 12px;
        align-items: center;
    }

    /* Оновлені мінімалістичні кнопки Edit/Delete */
    .icon-action-btn {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(255, 255, 255, 0.05);
        color: rgba(255, 255, 255, 0.7);
        border: 1px solid rgba(255, 255, 255, 0.1);
        transition: all 0.3s;
        text-decoration: none;
    }

        .icon-action-btn:hover {
            background: rgba(255, 255, 255, 0.15);
            color: #fff;
            transform: scale(1.05);
        }

        .icon-action-btn.delete:hover {
            background: rgba(255, 69, 58, 0.15);
            color: #ff453a;
            border-color: rgba(255, 69, 58, 0.3);
        }

    @@keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* ========================================= */
    /* LIVE DISCUSSION                           */
    /* ========================================= */
    .chat-container {
        margin-top: 60px;
        background: rgba(15, 18, 30, 0.2);
        backdrop-filter: blur(80px) saturate(200%);
        -webkit-backdrop-filter: blur(80px) saturate(200%);
        border-radius: 40px;
        padding: 40px 0 0 0;
        box-shadow: 0 40px 100px rgba(0, 0, 0, 0.6);
        position: relative;
        overflow: hidden;
    }

    .chat-header {
        font-size: 1.5rem;
        font-weight: 800;
        letter-spacing: -0.02em;
        color: #fff;
        margin-bottom: 10px;
        padding: 0 40px;
        display: flex;
        align-items: center;
        gap: 12px;
        position: relative;
        z-index: 1;
    }

    .pulse-dot {
        width: 12px;
        height: 12px;
        background-color: #00ffc8;
        border-radius: 50%;
        box-shadow: 0 0 15px #00ffc8;
        animation: pulse 2s infinite;
    }

    @@keyframes pulse {
        0% {
            box-shadow: 0 0 0 0 rgba(0, 255, 200, 0.4);
        }

        70% {
            box-shadow: 0 0 0 10px rgba(0, 255, 200, 0);
        }

        100% {
            box-shadow: 0 0 0 0 rgba(0, 255, 200, 0);
        }
    }

    .messages-box {
        height: 500px;
        overflow-y: auto;
        padding: 10px 40px 30px 40px;
        display: flex;
        flex-direction: column;
        position: relative;
        z-index: 1;
        scrollbar-width: none;
    }

        .messages-box::-webkit-scrollbar {
            display: none;
        }

    .date-badge {
        align-self: center;
        position: sticky;
        top: 0px;
        z-index: 5;
        background: rgba(20, 25, 40, 0.85);
        color: rgba(255, 255, 255, 0.8);
        padding: 6px 20px;
        border-radius: 30px;
        font-size: 0.75rem;
        font-weight: 600;
        margin: 10px 0 25px 0;
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.05);
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
    }

    .msg-wrapper {
        display: flex;
        width: 100%;
        margin-bottom: 16px;
    }

        .msg-wrapper.others {
            justify-content: flex-start;
        }

        .msg-wrapper.mine {
            justify-content: flex-end;
        }

    .msg-avatar {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: linear-gradient(135deg, rgba(255,255,255,0.1), rgba(255,255,255,0.02));
        border: 1px solid rgba(255,255,255,0.05);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.85rem;
        font-weight: bold;
        color: #fff;
        margin-right: 12px;
        align-self: flex-end;
        flex-shrink: 0;
        box-shadow: 0 5px 15px rgba(0,0,0,0.2);
    }

    .msg-bubble-container {
        display: flex;
        flex-direction: column;
        max-width: 70%;
    }

    .others .msg-bubble-container {
        align-items: flex-start;
    }

    .mine .msg-bubble-container {
        align-items: flex-end;
    }

    .msg-author-name {
        font-size: 0.75rem;
        color: #00ffc8;
        margin-left: 14px;
        margin-bottom: 4px;
        font-weight: 600;
    }

    .msg-bubble {
        padding: 12px 18px;
        font-size: 1rem;
        line-height: 1.5;
        position: relative;
        min-width: 70px;
        word-wrap: break-word;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
    }

    .others .msg-bubble {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.05);
        color: #fff;
        border-radius: 24px 24px 24px 8px;
        backdrop-filter: blur(20px);
    }

    .mine .msg-bubble {
        background: linear-gradient(135deg, rgba(0, 255, 200, 0.1), rgba(0, 200, 160, 0.02));
        border: 1px solid rgba(0, 255, 200, 0.2);
        color: #fff;
        border-radius: 24px 24px 8px 24px;
        backdrop-filter: blur(20px);
    }

    .msg-meta-inline {
        float: right;
        font-size: 0.7rem;
        margin-top: 6px;
        margin-left: 15px;
        margin-bottom: -2px;
        display: flex;
        align-items: center;
        gap: 4px;
        opacity: 0.5;
    }

    .mine .msg-meta-inline {
        color: #00ffc8;
        opacity: 0.8;
    }

    .chat-img-attachment {
        max-width: 100%;
        border-radius: 16px;
        margin-top: 4px;
        border: 1px solid rgba(255,255,255,0.05);
        max-height: 280px;
        object-fit: cover;
    }

    .input-area {
        padding: 0 40px 30px 40px;
        position: relative;
        z-index: 1;
    }

    .input-pill {
        display: flex;
        align-items: center;
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 40px;
        padding: 8px 10px 8px 20px;
        backdrop-filter: blur(30px);
        box-shadow: 0 20px 50px rgba(0,0,0,0.3);
        transition: all 0.3s;
        position: relative;
    }

        .input-pill:focus-within {
            background: rgba(255, 255, 255, 0.05);
            transform: translateY(-2px);
        }

    .btn-icon {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: transparent;
        border: none;
        color: rgba(255, 255, 255, 0.5);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
        cursor: pointer;
        transition: 0.2s;
    }

        .btn-icon:hover {
            color: #fff;
            background: rgba(255, 255, 255, 0.08);
        }

    .btn-send {
        background: #00ffc8;
        color: #0f121e;
        box-shadow: 0 2px 8px rgba(0, 255, 200, 0.15);
    }

        .btn-send:hover {
            background: #00e6b4;
            color: #0f121e;
            transform: scale(1.03);
            box-shadow: 0 4px 12px rgba(0, 255, 200, 0.25);
        }

        .btn-send:active {
            transform: scale(0.97);
        }

    .chat-input {
        flex-grow: 1;
        background: transparent;
        border: none;
        color: #fff;
        font-size: 1.05rem;
        padding: 10px 15px;
        outline: none;
    }

        .chat-input::placeholder {
            color: rgba(255, 255, 255, 0.3);
        }

    #fileNameDisplay {
        position: absolute;
        top: -30px;
        left: 25px;
        font-size: 0.8rem;
        color: #00ffc8;
        font-weight: 600;
        text-shadow: 0 2px 10px rgba(0,0,0,0.5);
    }
</style>

<div class="reader-container py-5">

    @if (TempData["Message"] != null)
    {
        <div style="color: #00ffc8; margin-bottom: 20px; font-weight: 500; background: rgba(0, 255, 200, 0.1); padding: 12px 20px; border-radius: 12px; border: 1px solid rgba(0, 255, 200, 0.2);">
            ✓ @TempData["Message"]
        </div>
    }

    <div class="reading-glass">

        <header>
            <h1 class="article-title">@Model.Title</h1>

            <div class="meta-row">
                <div class="meta-item">
                    <span class="meta-label">Date</span>
                    <span class="meta-value">@Model.PublicationDate.ToString("MMM dd, yyyy")</span>
                </div>

                <div class="meta-item">
                    <span class="meta-label">Category</span>
                    <span class="meta-value">@Model.Category</span>
                </div>

                <div class="meta-item">
                    <span class="meta-label">Rating</span>
                    <span class="rating-badge rating-pill-display">
                        ★ @Model.Rating.ToString("0.0")
                    </span>
                </div>
            </div>
        </header>

        <article class="prose-content">
            @Model.Content
        </article>

        @if (Model.ArticleAuthors != null && Model.ArticleAuthors.Any())
        {
            <div class="authors-section">
                <div class="meta-label" style="margin-bottom: 12px;">WRITTEN BY</div>
                @foreach (var link in Model.ArticleAuthors)
                {
                    var initial = link.Author.FullName.Substring(0, 1);
                    <a asp-controller="Authors" asp-action="Details" asp-route-id="@link.AuthorId" class="author-chip">
                        <div class="author-avatar">@initial</div>
                        @link.Author.FullName
                    </a>
                }
            </div>
        }

        @if (User.Identity.IsAuthenticated)
        {
            if (ViewBag.HasProfile == true)
            {
                @if (Model.UserId != currentUserId)
                {
                    <div class="rating-container">
                        <div class="rating-title">Rate this Article</div>
                        <div class="stars-wrapper" id="articleStars">
                            @for (int i = 1; i <= 10; i++)
                            {
                                <button type="button" class="star-btn" data-value="@i" title="@i/10">
                                    <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path></svg>
                                </button>
                            }
                        </div>

                        <form id="ratingForm" asp-action="RateArticle" method="post" style="display: none;">
                            <input type="hidden" name="articleId" value="@Model.Id" />
                            <input type="hidden" name="score" id="scoreInput" value="0" />
                        </form>

                        <button type="button" id="confirmArticleRating" class="btn-confirm-rating">Submit Rating</button>
                        <div id="ratingFeedback" style="font-size: 0.85rem; color: #00ffc8; margin-top: 15px; opacity: 0; font-weight: 600; transition: opacity 0.3s; display: none;">
                            Thanks for your rating!
                        </div>
                    </div>
                }

                <div class="action-bar">
                    <a asp-action="Index" class="btn-back">
                        <span>&larr;</span> Library
                    </a>

                    @if (User.IsInRole("Admin"))
                    {
                        <div class="btn-group-actions">
                            <a asp-action="Edit" asp-route-id="@Model.Id" class="icon-action-btn" title="Edit Article">
                                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
                            </a>
                            <a asp-action="Delete" asp-route-id="@Model.Id" class="icon-action-btn delete" title="Delete Article">
                                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
                            </a>
                        </div>
                    }
                </div>

                <div class="chat-container">
                    <div class="chat-header">
                        <div class="pulse-dot"></div> Live Discussion
                    </div>

                    <div class="messages-box" id="messagesList">
                        @{
                            DateTime? lastDate = null;
                        }

                        @if (ViewBag.ChatHistory != null)
                        {
                            foreach (var msg in ViewBag.ChatHistory)
                            {
                                var msgDate = msg.SentAt.Date;
                                if (lastDate != msgDate)
                                {
                                    <div class="date-badge">@msgDate.ToString("MMMM dd")</div>
                                    lastDate = msgDate;
                                }

                                var isMine = msg.Sender.FullName == ViewBag.CurrentAuthorName;
                                var wrapperClass = isMine ? "mine" : "others";
                                var initial = !string.IsNullOrEmpty(msg.Sender.FullName) ? msg.Sender.FullName.Substring(0, 1).ToUpper() : "?";

                                <div class="msg-wrapper @wrapperClass">
                                    @if (!isMine)
                                    {
                                        <div class="msg-avatar">@initial</div>
                                    }

                                    <div class="msg-bubble-container">
                                        @if (!isMine)
                                        {
                                            <div class="msg-author-name">@msg.Sender.FullName</div>
                                        }
                                        <div class="msg-bubble">
                                            @if (!string.IsNullOrEmpty(msg.AttachmentUrl))
                                            {
                                                <img src="@msg.AttachmentUrl" class="chat-img-attachment" alt="attachment" />
                                            }
                                            @if (!string.IsNullOrEmpty(msg.Content))
                                            {
                                                <div class="msg-content">@msg.Content</div>
                                            }
                                            <div class="msg-meta-inline">@msg.SentAt.ToString("HH:mm")</div>
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                    </div>

                    <div class="input-area">
                        <div class="input-pill">
                            <label for="fileInput" class="btn-icon" title="Attach Image">
                                <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"></path></svg>
                            </label>
                            <input type="file" id="fileInput" style="display: none;" accept="image/*" />
                            <div id="fileNameDisplay"></div>
                            <input type="text" id="messageInput" class="chat-input" placeholder="Share your thoughts..." autocomplete="off" />
                            <button id="sendButton" class="btn-icon btn-send">
                                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="19" x2="12" y2="5"></line><polyline points="5 12 12 5 19 12"></polyline></svg>
                            </button>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="locked-glass-panel">
                    <div class="lock-icon-wrapper">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                            <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                        </svg>
                    </div>
                    <h3 class="locked-title">Unlock Interactions</h3>
                    <p class="locked-subtitle">
                        To maintain a high-quality community, you need to establish your identity. Complete your author profile to rate articles and join live discussions.
                    </p>
                    <a asp-controller="Cabinet" asp-action="InitializeProfile" class="btn-unlock-glass">
                        Setup Profile
                    </a>
                </div>
            }
        }
        else
        {
            <div class="locked-glass-panel">
                <div class="lock-icon-wrapper">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                        <circle cx="12" cy="7" r="4"></circle>
                    </svg>
                </div>
                <h3 class="locked-title">Join the Conversation</h3>
                <p class="locked-subtitle">
                    Sign in to your account to rate this article and interact with other readers in the live discussion.
                </p>
                <a asp-area="Identity" asp-page="/Account/Login" class="btn-unlock-glass">
                    Sign In
                </a>
            </div>
        }
    </div>
</div>

<div class="lightbox-overlay" id="imageLightbox">
    <div class="lightbox-close" id="closeLightbox">&times;</div>
    <img src="" class="lightbox-image" id="lightboxImg" alt="Enlarged view" />
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // === ЛОГІКА ОЦІНЮВАННЯ СТАТТІ ===
            const stars = document.querySelectorAll('.star-btn');
            const confirmBtn = document.getElementById('confirmArticleRating');
            const feedback = document.getElementById('ratingFeedback');
            const form = document.getElementById('ratingForm');
            const scoreInput = document.getElementById('scoreInput');

            if(stars.length > 0 && confirmBtn) {
                stars.forEach(star => {
                    star.addEventListener('mouseenter', function() {
                        const hoverValue = this.getAttribute('data-value');
                        stars.forEach(s => {
                            if(parseInt(s.getAttribute('data-value')) <= parseInt(hoverValue)) s.classList.add('hover-active');
                            else s.classList.remove('hover-active');
                        });
                    });

                    star.addEventListener('mouseleave', function() {
                        stars.forEach(s => s.classList.remove('hover-active'));
                    });

                    star.addEventListener('click', function() {
                        const selectedValue = this.getAttribute('data-value');
                        scoreInput.value = selectedValue;

                        stars.forEach(s => {
                            if(parseInt(s.getAttribute('data-value')) <= parseInt(selectedValue)) s.classList.add('active');
                            else s.classList.remove('active');
                        });

                        confirmBtn.style.display = 'inline-block';
                        feedback.style.display = 'none';
                        feedback.style.opacity = '0';
                    });
                });

                confirmBtn.addEventListener('click', function() {
                    form.submit();
                });
            }

            // === ЛОГІКА ЧАТУ ===
            const articleId = "@Model.Id";
            const currentUserName = "@Html.Raw(ViewBag.CurrentAuthorName)";

            const messageInput = document.getElementById("messageInput");
            const sendButton = document.getElementById("sendButton");
            const messagesList = document.getElementById("messagesList");
            const fileInput = document.getElementById("fileInput");
            const fileNameDisplay = document.getElementById("fileNameDisplay");

            let lastMessageDate = "";
            const dateBadges = document.querySelectorAll('.date-badge');
            if (dateBadges.length > 0) lastMessageDate = dateBadges[dateBadges.length - 1].innerText;

            if(messagesList) messagesList.scrollTop = messagesList.scrollHeight;

            const connection = new signalR.HubConnectionBuilder().withUrl("/chatHub").build();

            connection.on("ReceiveArticleMessage", function (user, message, time, attachmentUrl) {
                const isMine = user === currentUserName;
                const wrapperClass = isMine ? "mine" : "others";
                const initial = user ? user.substring(0, 1).toUpperCase() : "?";

                const today = new Date().toLocaleDateString('en-US', { month: 'long', day: 'numeric' });
                if (today !== lastMessageDate) {
                    const dateDiv = document.createElement("div");
                    dateDiv.className = "date-badge"; dateDiv.innerText = today;
                    messagesList.appendChild(dateDiv);
                    lastMessageDate = today;
                }

                let html = "";
                if (!isMine) html += `<div class="msg-avatar">${initial}</div>`;
                html += `<div class="msg-bubble-container">`;
                if (!isMine) html += `<div class="msg-author-name">${user}</div>`;
                html += `<div class="msg-bubble">`;
                if (attachmentUrl) html += `<img src="${attachmentUrl}" class="chat-img-attachment" />`;
                if (message) html += `<div class="msg-content">${message}</div>`;
                html += `<div class="msg-meta-inline">${time}</div></div></div>`;

                const div = document.createElement("div");
                div.className = `msg-wrapper ${wrapperClass}`;
                div.innerHTML = html;

                messagesList.appendChild(div);
                messagesList.scrollTop = messagesList.scrollHeight;
            });

            connection.start().then(function () {
                connection.invoke("JoinArticleGroup", articleId).catch(err => console.error(err));
                if (sendButton) sendButton.disabled = false;
            }).catch(err => console.error(err));

            if(fileInput) {
                fileInput.addEventListener("change", function() {
                    fileNameDisplay.innerText = this.files.length > 0 ? "📎 " + this.files[0].name : "";
                });
            }

            function sendMessage() {
                const message = messageInput.value.trim();
                const file = fileInput.files[0];
                if (message === "" && !file) return;

                const originalIcon = sendButton.innerHTML;
                sendButton.innerHTML = "⏳";
                sendButton.disabled = true;

                if (file) {
                    const formData = new FormData(); formData.append("file", file);
                    fetch('/api/chatupload/upload', { method: 'POST', body: formData })
                    .then(response => response.json())
                    .then(data => {
                        connection.invoke("SendArticleMessage", parseInt(articleId), message, data.url).catch(err => console.error(err));
                        resetInputs(originalIcon);
                    })
                    .catch(error => { console.error('Error:', error); resetInputs(originalIcon); });
                } else {
                    connection.invoke("SendArticleMessage", parseInt(articleId), message, null).catch(err => console.error(err));
                    resetInputs(originalIcon);
                }
            }

            function resetInputs(icon) {
                messageInput.value = ""; fileInput.value = ""; fileNameDisplay.innerText = "";
                sendButton.innerHTML = icon; sendButton.disabled = false; messageInput.focus();
            }

            if(sendButton) {
                sendButton.addEventListener("click", e => { sendMessage(); e.preventDefault(); });
                messageInput.addEventListener("keypress", e => { if (e.key === "Enter") { sendMessage(); e.preventDefault(); } });
            }

            const lightbox = document.getElementById('imageLightbox');
            const lightboxImg = document.getElementById('lightboxImg');
            const closeLightbox = document.getElementById('closeLightbox');

            if(messagesList) {
                messagesList.addEventListener('click', function(e) {
                    if (e.target && e.target.classList.contains('chat-img-attachment')) {
                        lightboxImg.src = e.target.src;
                        lightbox.classList.add('active');
                    }
                });
            }

            closeLightbox.addEventListener('click', () => lightbox.classList.remove('active'));
            lightbox.addEventListener('click', function(e) {
                if (e.target === lightbox) lightbox.classList.remove('active');
            });

            function sendMessage() {
                const message = messageInput.value.trim();
                const file = fileInput.files[0];
                if (message === "" && !file) return;

                if (file) {
                    if (file.size > 5 * 1024 * 1024) {
                        alert("File is too large. Maximum size is 5MB.");
                        return;
                    }
                    const validTypes = ['image/jpeg', 'image/png', 'image/gif', 'image/webp'];
                    if (!validTypes.includes(file.type)) {
                        alert("Invalid file type. Please select a JPG, PNG, GIF, or WEBP image.");
                        return;
                    }
                }

                const originalIcon = sendButton.innerHTML;
                sendButton.innerHTML = "⏳";
                sendButton.disabled = true;

                if (file) {
                    const formData = new FormData();
                    formData.append("file", file);

                    fetch('/api/chatupload/upload', { method: 'POST', body: formData })
                    .then(response => response.json())
                    .then(data => {
                        if (data.url) {
                            connection.invoke("SendArticleMessage", parseInt(articleId), message, data.url).catch(err => console.error(err));
                            resetInputs(originalIcon);
                        } else {
                            alert("Upload failed: " + data.message);
                            resetInputs(originalIcon);
                        }
                    })
                    .catch(error => {
                        console.error('Error:', error);
                        alert("Error uploading file.");
                        resetInputs(originalIcon);
                    });
                } else {
                    connection.invoke("SendArticleMessage", parseInt(articleId), message, null).catch(err => console.error(err));
                    resetInputs(originalIcon);
                }
            }
        });
    </script>
}