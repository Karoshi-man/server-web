@using System.Security.Claims
@model IEnumerable<lab1.Models.Article>

@{
    ViewData["Title"] = "Library";
}

<style>
    .library-header {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        margin-bottom: 50px;
        padding-top: 60px;
        position: relative;
        /* ПРИБРАНО .library-header::before */
    }

    .library-title {
        font-size: 4rem;
        font-weight: 800;
        letter-spacing: -0.04em;
        line-height: 1;
        color: #fff;
        margin-bottom: 16px;
        /* Легка текстова тінь замість глобального світіння */
        text-shadow: 0 5px 15px rgba(0,0,0,0.3);
    }

    .library-subtitle {
        font-size: 1.2rem;
        color: rgba(255, 255, 255, 0.5);
        font-weight: 400;
        max-width: 500px;
        margin-bottom: 30px;
    }

    .btn-create-glass {
        background: rgba(0, 255, 200, 0.1);
        color: #00ffc8;
        padding: 14px 36px;
        border-radius: 40px;
        text-decoration: none;
        font-weight: 600;
        font-size: 1rem;
        border: 1px solid rgba(0, 255, 200, 0.3);
        backdrop-filter: blur(20px);
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        display: inline-flex;
        align-items: center;
        gap: 10px;
        box-shadow: 0 10px 30px rgba(0, 255, 200, 0.1);
    }

        .btn-create-glass:hover {
            background: #00ffc8;
            color: #0a0f1e;
            transform: translateY(-4px) scale(1.02);
            box-shadow: 0 15px 40px rgba(0, 255, 200, 0.3);
        }

    .controls-bar {
        display: flex;
        gap: 16px;
        align-items: center;
        margin-bottom: 40px;
        flex-wrap: wrap;
    }

    .search-wrapper {
        flex-grow: 1;
        position: relative;
        min-width: 250px;
    }

    .search-icon {
        position: absolute;
        left: 18px;
        top: 50%;
        transform: translateY(-50%);
        color: rgba(255,255,255,0.4);
        pointer-events: none;
        transition: color 0.3s;
    }

    .glass-search {
        width: 100%;
        padding: 14px 20px 14px 50px;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 30px;
        color: #fff;
        font-size: 0.95rem;
        font-weight: 500;
        backdrop-filter: blur(30px);
        -webkit-backdrop-filter: blur(30px);
        transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
        box-shadow: inset 0 2px 5px rgba(0,0,0,0.2);
    }

        .glass-search:focus {
            outline: none;
            background: rgba(255, 255, 255, 0.06);
        }

            .glass-search:focus + .search-icon {
                color: #00ffc8;
            }

        .glass-search::placeholder {
            color: rgba(255,255,255,0.3);
        }

    .glass-select {
        appearance: none;
        -webkit-appearance: none;
        background: rgba(255, 255, 255, 0.03) url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='rgba(255,255,255,0.5)' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'%3e%3cpolyline points='6 9 12 15 18 9'%3e%3c/polyline%3e%3c/svg%3e") no-repeat right 16px center;
        background-size: 16px;
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 30px;
        color: #fff;
        padding: 14px 45px 14px 20px;
        font-size: 0.95rem;
        font-weight: 500;
        cursor: pointer;
        backdrop-filter: blur(30px);
        -webkit-backdrop-filter: blur(30px);
        transition: all 0.3s ease;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    }

        .glass-select:focus, .glass-select:hover {
            outline: none;
            background-color: rgba(255, 255, 255, 0.08);
            border-color: rgba(255, 255, 255, 0.2);
        }
        /* Стилізація опцій всередині (наскільки це можливо) */
        .glass-select option {
            background: #121624;
            color: #fff;
            padding: 10px;
            border-radius: 30px;
        }

    .editorial-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
        gap: 30px;
    }

    .editorial-card {
        position: relative;
        background: rgba(20, 24, 38, 0.4);
        backdrop-filter: blur(60px) saturate(150%);
        -webkit-backdrop-filter: blur(60px) saturate(150%);
        border-radius: 32px;
        padding: 36px;
        display: flex;
        flex-direction: column;
        transition: all 0.5s cubic-bezier(0.2, 0.8, 0.2, 1);
        border: 1px solid rgba(255, 255, 255, 0.03);
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4), inset 0 1px 0 rgba(255, 255, 255, 0.05);
        z-index: 1;
        overflow: hidden;
    }

        .editorial-card::before {
            content: '';
            position: absolute;
            inset: 0;
            border-radius: 32px;
            background: radial-gradient(80% 80% at 50% -20%, rgba(0, 255, 200, 0.12), transparent);
            opacity: 0;
            transition: opacity 0.5s ease;
            z-index: -1;
            pointer-events: none;
        }

        .editorial-card:hover {
            transform: translateY(-8px) scale(1.01);
            border-color: rgba(255, 255, 255, 0.12);
            box-shadow: 0 30px 60px rgba(0, 0, 0, 0.5), inset 0 1px 0 rgba(255, 255, 255, 0.1);
        }

            .editorial-card:hover::before {
                opacity: 1;
            }

    .card-topbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 24px;
    }

    .cat-indicator {
        font-size: 0.75rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: #fff;
        position: relative;
        display: inline-block;
    }

        .cat-indicator::after {
            content: '';
            position: absolute;
            left: 0;
            bottom: -4px;
            width: 20px;
            height: 3px;
            background-color: #00ffc8;
            border-radius: 4px;
        }

    .card-date {
        font-size: 0.8rem;
        color: rgba(255, 255, 255, 0.4);
        font-weight: 500;
    }

    .article-title {
        font-size: 1.8rem;
        font-weight: 700;
        line-height: 1.2;
        color: #fff;
        margin-bottom: 16px;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .rating-glass {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        background: rgba(255, 214, 10, 0.1);
        border: 1px solid rgba(255, 214, 10, 0.2);
        color: #FFD60A;
        padding: 6px 14px;
        border-radius: 30px;
        font-size: 0.85rem;
        font-weight: 700;
        margin-bottom: 24px;
        align-self: flex-start;
    }

    .article-excerpt {
        font-size: 1rem;
        color: rgba(255, 255, 255, 0.5);
        line-height: 1.6;
        flex-grow: 1;
        margin-bottom: 30px;
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .card-bottom {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        position: relative;
        z-index: 2;
    }

    .read-action {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 44px;
        height: 44px;
        border-radius: 50%;
        background: rgba(255,255,255,0.05);
        color: #fff;
        transition: all 0.3s;
        cursor: pointer;
    }

    .editorial-card:hover .read-action {
        background: #fff;
        color: #000;
        transform: translateX(5px);
    }

    .admin-actions {
        display: flex;
        gap: 8px;
        opacity: 0;
        transform: translateY(10px);
        transition: all 0.4s ease;
    }

    .editorial-card:hover .admin-actions {
        opacity: 1;
        transform: translateY(0);
    }

    .action-glass-btn {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(255,255,255,0.1);
        border: 1px solid rgba(255,255,255,0.05);
        color: #fff;
        backdrop-filter: blur(10px);
        transition: all 0.2s;
    }

        .action-glass-btn:hover {
            background: rgba(255,255,255,0.2);
            transform: scale(1.1);
        }

        .action-glass-btn.delete:hover {
            background: rgba(255, 69, 58, 0.2);
            color: #ff453a;
            border-color: rgba(255, 69, 58, 0.3);
        }

    .stretched-link::after {
        content: "";
        position: absolute;
        top: 0;
        right: 0;
        bottom: 0;
        left: 0;
        z-index: 1;
    }

    .admin-actions, .card-topbar, .rating-glass {
        position: relative;
        z-index: 2;
    }

    .no-results {
        grid-column: 1 / -1;
        text-align: center;
        padding: 60px 20px;
        color: rgba(255,255,255,0.4);
        font-size: 1.2rem;
        display: none;
    }

    .glass-toast {
        position: fixed;
        bottom: 40px;
        right: 40px;
        background: rgba(20, 24, 38, 0.85);
        backdrop-filter: blur(20px) saturate(150%);
        -webkit-backdrop-filter: blur(20px) saturate(150%);
        border: 1px solid rgba(0, 255, 200, 0.3);
        border-radius: 20px;
        padding: 16px 24px;
        color: #fff;
        font-size: 0.95rem;
        font-weight: 500;
        display: flex;
        align-items: center;
        gap: 16px;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.5), 0 0 20px rgba(0, 255, 200, 0.1);
        z-index: 9999;
        animation: slideInToast 0.5s cubic-bezier(0.2, 0.8, 0.2, 1) forwards, fadeOutToast 0.5s ease 5s forwards;
    }

    .toast-icon {
        background: rgba(0, 255, 200, 0.15);
        border-radius: 50%;
        width: 36px;
        height: 36px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #00ffc8;
        flex-shrink: 0;
    }

    @@keyframes slideInToast {
        from {
            transform: translateY(100px) scale(0.9);
            opacity: 0;
        }

        to {
            transform: translateY(0) scale(1);
            opacity: 1;
        }
    }

    @@keyframes fadeOutToast {
        from {
            transform: translateY(0);
            opacity: 1;
        }

        to {
            transform: translateY(20px);
            opacity: 0;
            pointer-events: none;
        }
    }
</style>

<div class="container pb-5">
    @if (TempData["Message"] != null)
    {
        <div class="glass-toast">
            <div class="toast-icon">
                <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
            </div>
            <div>@TempData["Message"]</div>
        </div>
    }

    <div class="library-header">
        <h1 class="library-title">Library</h1>
        <p class="library-subtitle">A seamless collection of your thoughts, ideas, and stories.</p>

        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Create" class="btn-create-glass">
                <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                Write an Article
            </a>
        }
    </div>

    <div class="controls-bar">
        <div class="search-wrapper">
            <input type="text" id="liveSearchInput" class="glass-search" placeholder="Search articles by title or content..." autocomplete="off" />
            <svg class="search-icon" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
        </div>

        <form method="get" id="filterForm" style="display: flex; gap: 16px;">
            <select name="category" class="glass-select" onchange="document.getElementById('filterForm').submit();">
                <option value="All">All Categories</option>
                @if (ViewBag.Categories != null)
                {
                    foreach (var cat in (IEnumerable<string>)ViewBag.Categories)
                    {
                        <option value="@cat" selected="@(ViewBag.CurrentCategory == cat ? "selected" : null)">@cat</option>
                    }
                }
            </select>

            <select name="sortBy" class="glass-select" onchange="document.getElementById('filterForm').submit();">
                <option value="newest" selected="@(ViewBag.CurrentSort == "newest" ? "selected" : null)">Newest First</option>
                <option value="oldest" selected="@(ViewBag.CurrentSort == "oldest" ? "selected" : null)">Oldest First</option>
                <option value="rating" selected="@(ViewBag.CurrentSort == "rating" ? "selected" : null)">Highest Rating</option>
                <option value="top_author" selected="@(ViewBag.CurrentSort == "top_author" ? "selected" : null)">Top Authors</option>
            </select>
        </form>
    </div>

    <div class="editorial-grid" id="articlesGrid">
        @foreach (var item in Model)
        {
            <div class="editorial-card article-item">
                <div class="card-topbar">
                    <div class="cat-indicator">
                        @item.Category
                    </div>
                    <div class="card-date">@item.PublicationDate.ToString("MMM dd, yyyy")</div>
                </div>

                <a asp-action="Details" asp-route-id="@item.Id" class="stretched-link" style="text-decoration: none;">
                    <h2 class="article-title searchable-title">@item.Title</h2>
                </a>

                <div class="rating-glass">
                    <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path></svg>
                    @(item.Rating > 0 ? item.Rating.ToString("0.0") : "N/A")
                </div>

                <p class="article-excerpt searchable-content">
                    @item.Content
                </p>

                <div class="card-bottom">
                    <div class="read-action">
                        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                    </div>

                    <div class="admin-actions">
                        @{
                            var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
                            var isAdmin = User.IsInRole("Admin");
                        }

                        @if (item.UserId == currentUserId || isAdmin)
                        {
                            <a asp-action="Edit" asp-route-id="@item.Id" class="action-glass-btn" title="Edit Article">
                                <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="action-glass-btn delete" title="Delete Article">
                                <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
                            </a>
                        }
                    </div>
                </div>
            </div>
        }

        <div id="noResultsMsg" class="no-results">
            <svg viewBox="0 0 24 24" width="48" height="48" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" style="margin-bottom: 15px; opacity: 0.5;"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
            <div>No articles found matching your search.</div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const searchInput = document.getElementById("liveSearchInput");
            const articles = document.querySelectorAll(".article-item");
            const noResultsMsg = document.getElementById("noResultsMsg");

            searchInput.addEventListener("input", function (e) {
                const term = e.target.value.toLowerCase().trim();
                let hasVisibleCards = false;

                articles.forEach(card => {
                    const title = card.querySelector(".searchable-title").innerText.toLowerCase();
                    const content = card.querySelector(".searchable-content").innerText.toLowerCase();

                    if (title.includes(term) || content.includes(term)) {
                        card.style.display = "flex";
                        hasVisibleCards = true;
                        setTimeout(() => {
                            card.style.opacity = "1";
                            card.style.transform = "scale(1)";
                        }, 10);
                    } else {
                        card.style.opacity = "0";
                        card.style.transform = "scale(0.95)";
                        setTimeout(() => {
                            card.style.display = "none";
                        }, 300);
                    }
                });

                if (!hasVisibleCards && term !== "") {
                    setTimeout(() => { noResultsMsg.style.display = "block"; }, 300);
                } else {
                    noResultsMsg.style.display = "none";
                }
            });
        });
    </script>
}