@model lab1.Models.Author
@using System.Security.Claims

@{
    ViewData["Title"] = Model.FullName;
    var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
}

<style>
    .profile-bg-glow {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100vh;
        background: radial-gradient(ellipse at top, rgba(100, 150, 255, 0.12) 0%, transparent 60%);
        z-index: -1;
        pointer-events: none;
    }

    .profile-view-container {
        max-width: 850px;
        margin: 0 auto;
        padding-top: 60px;
        animation: fadeUp 0.8s cubic-bezier(0.2, 0.8, 0.2, 1);
        position: relative;
    }

    .glass-profile {
        background: rgba(20, 24, 38, 0.4);
        backdrop-filter: blur(60px) saturate(150%);
        -webkit-backdrop-filter: blur(60px) saturate(150%);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 40px;
        padding: 60px;
        box-shadow: 0 40px 100px rgba(0, 0, 0, 0.5), inset 0 1px 0 rgba(255, 255, 255, 0.05);
        position: relative;
        overflow: hidden;
    }

    .profile-header {
        text-align: center;
        margin-bottom: 40px;
    }

    .profile-avatar-large {
        width: 140px;
        height: 140px;
        border-radius: 50%;
        background: linear-gradient(135deg, rgba(255,255,255,0.1), rgba(255,255,255,0.02));
        margin: 0 auto 24px auto;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 4rem;
        font-weight: 800;
        color: #fff;
        box-shadow: 0 15px 35px rgba(0,0,0,0.3), inset 0 0 0 1px rgba(255,255,255,0.1);
    }

    .profile-name-large {
        font-size: 2.8rem;
        font-weight: 800;
        color: #fff;
        margin-bottom: 8px;
        letter-spacing: -0.03em;
        text-shadow: 0 5px 15px rgba(0,0,0,0.3);
    }

    .profile-handle-large {
        font-size: 1.2rem;
        color: #8cb4ff;
        margin-bottom: 24px;
        font-weight: 500;
    }

    .profile-meta-row {
        display: flex;
        justify-content: center;
        gap: 16px;
        margin-bottom: 40px;
        flex-wrap: wrap;
    }

    .meta-chip {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: rgba(255, 255, 255, 0.03);
        padding: 10px 20px;
        border-radius: 30px;
        font-size: 0.9rem;
        font-weight: 500;
        color: #fff;
        border: 1px solid rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(20px);
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    }

        .meta-chip svg {
            color: rgba(255,255,255,0.5);
        }

    /* === ВИПРАВЛЕНА СИСТЕМА ОЦІНЮВАННЯ === */
    .rating-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        margin-bottom: 50px;
        background: rgba(0,0,0,0.2);
        padding: 24px;
        border-radius: 24px;
        border: 1px solid rgba(255,255,255,0.03);
    }

    .rating-title {
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: rgba(255,255,255,0.5);
        margin-bottom: 12px;
        font-weight: 700;
    }

    .stars-wrapper {
        display: flex;
        gap: 8px;
    }

    .star-btn {
        background: transparent;
        border: none;
        cursor: pointer;
        padding: 0;
        color: rgba(255, 255, 255, 0.15);
        transition: all 0.2s cubic-bezier(0.25, 0.8, 0.25, 1);
    }

        .star-btn svg {
            width: 34px;
            height: 34px;
            transition: transform 0.2s;
        }

        /* Класи для плавної роботи через JS */
        .star-btn.hover-active {
            color: #FFD60A;
            opacity: 0.6;
            transform: scale(1.1);
        }

        .star-btn.active {
            color: #FFD60A;
            drop-shadow: 0 0 10px rgba(255, 214, 10, 0.5);
            transform: scale(1.15);
        }

    /* Кнопка підтвердження */
    .btn-confirm-rating {
        background: rgba(0, 255, 200, 0.1);
        color: #00ffc8;
        border: 1px solid rgba(0, 255, 200, 0.3);
        padding: 8px 24px;
        border-radius: 30px;
        font-size: 0.85rem;
        font-weight: 600;
        margin-top: 20px;
        cursor: pointer;
        transition: all 0.3s;
        display: none; /* Прихована за замовчуванням */
        box-shadow: 0 5px 15px rgba(0, 255, 200, 0.1);
    }

        .btn-confirm-rating:hover {
            background: #00ffc8;
            color: #0a0f1e;
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(0, 255, 200, 0.25);
        }

    .bio-box {
        text-align: center;
        max-width: 650px;
        margin: 0 auto 60px auto;
        font-size: 1.15rem;
        line-height: 1.7;
        color: rgba(255, 255, 255, 0.7);
    }

    /* === СПИСОК СТАТЕЙ === */
    .publications-wrapper {
        padding-top: 10px;
    }

    .section-label {
        font-size: 0.8rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: #fff;
        margin-bottom: 24px;
        display: flex;
        align-items: center;
        gap: 10px;
        text-align: left;
    }

        .section-label::after {
            content: '';
            flex-grow: 1;
            height: 1px;
            background: rgba(255,255,255,0.05);
        }

    .pub-list {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .pub-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: rgba(255, 255, 255, 0.02);
        padding: 24px 30px;
        border-radius: 24px;
        text-decoration: none;
        border: 1px solid rgba(255, 255, 255, 0.03);
        transition: all 0.3s cubic-bezier(0.2, 0.8, 0.2, 1);
        box-shadow: 0 10px 20px rgba(0,0,0,0.1);
    }

        .pub-item:hover {
            background: rgba(255, 255, 255, 0.05);
            transform: translateX(8px);
            border-color: rgba(255, 255, 255, 0.1);
            box-shadow: 0 15px 30px rgba(0,0,0,0.2);
        }

    .pub-info {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .pub-title {
        color: #fff;
        font-weight: 700;
        font-size: 1.1rem;
    }

    .pub-date {
        color: rgba(255, 255, 255, 0.4);
        font-size: 0.85rem;
    }

    .pub-arrow {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: rgba(255,255,255,0.05);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        transition: 0.3s;
    }

    .pub-item:hover .pub-arrow {
        background: #fff;
        color: #000;
    }

    .empty-state {
        text-align: center;
        padding: 50px;
        color: rgba(255, 255, 255, 0.3);
        background: rgba(0,0,0,0.2);
        border-radius: 24px;
        border: 1px dashed rgba(255,255,255,0.05);
    }

    .profile-actions {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 60px;
        padding-top: 40px;
        border-top: 1px solid rgba(255, 255, 255, 0.05);
    }

    .btn-edit-profile {
        background: #fff;
        color: #000;
        text-decoration: none;
        padding: 14px 36px;
        border-radius: 40px;
        font-weight: 600;
        font-size: 1rem;
        transition: all 0.3s;
        box-shadow: 0 10px 20px rgba(255, 255, 255, 0.1);
        display: flex;
        gap: 8px;
        align-items: center;
    }

        .btn-edit-profile:hover {
            transform: scale(1.05);
            box-shadow: 0 15px 30px rgba(255, 255, 255, 0.2);
            background: #f0f0f0;
        }

    .btn-back {
        display: flex;
        align-items: center;
        gap: 8px;
        color: rgba(255, 255, 255, 0.5);
        text-decoration: none;
        font-size: 1rem;
        font-weight: 500;
        transition: color 0.2s;
    }

        .btn-back:hover {
            color: #fff;
        }

    @@keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

    <div class="profile-bg-glow"></div>

    <div class="profile-view-container pb-5">
        <div class="glass-profile">

            <div class="profile-header">
                @{
                    var initial = !string.IsNullOrEmpty(Model.FullName) ? Model.FullName.Substring(0, 1).ToUpper() : "?";
                }
                <div class="profile-avatar-large">@initial</div>

                <h1 class="profile-name-large">@Model.FullName</h1>

                <div class="profile-handle-large">
                    @(string.IsNullOrEmpty(Model.Nickname) ? "" : "@" + Model.Nickname)
                </div>

                <div class="profile-meta-row">
                    <div class="meta-chip">
                        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
                        @Model.Email
                    </div>
                    <div class="meta-chip">
                        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
                        @{
                            var today = DateTime.Today;
                            var age = today.Year - Model.DateOfBirth.Year;
                            if (Model.DateOfBirth.Date > today.AddYears(-age)) age--;
                        }
                        @age years old
                    </div>
                    <div class="meta-chip" id="ratingPill">
                        <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path></svg>
                        @(Model.Rating > 0 ? Model.Rating.ToString("0.0") : "N/A")
                    </div>
                </div>
            </div>

            <div class="bio-box">
                @if (!string.IsNullOrEmpty(Model.Bio))
                {
                    @Model.Bio
                }
                else
                {
                    <span style="opacity: 0.4; font-style: italic;">This author hasn't shared a biography yet.</span>
                }
            </div>

            @if (Model.UserId != currentUserId)
            {
                @if (ViewBag.HasProfile == true)
                {
                <div class="rating-container">
                    <div class="rating-title">Rate this Author</div>
                    <div class="stars-wrapper" id="ratingStars">
                        @for (int i = 1; i <= 10; i++)
                        {
                            <button type="button" class="star-btn" data-value="@i">
                                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path></svg>
                            </button>
                        }
                    </div>
                    <button id="confirmRatingBtn" class="btn-confirm-rating">Confirm Rating</button>
                    <div id="ratingFeedback" style="font-size: 0.85rem; color: #00ffc8; margin-top: 15px; opacity: 0; font-weight: 600; transition: opacity 0.3s; display: none;">
                        Thanks for your feedback
                    </div>
                </div>
            }
         } 

            <div class="publications-wrapper">
                <span class="section-label">Publications (@(Model.ArticleAuthors?.Count ?? 0))</span>

                <div class="pub-list">
                    @if (Model.ArticleAuthors != null && Model.ArticleAuthors.Any())
                    {
                        @foreach (var link in Model.ArticleAuthors)
                        {
                            <a asp-controller="Articles" asp-action="Details" asp-route-id="@link.ArticleId" class="pub-item">
                                <div class="pub-info">
                                    <span class="pub-title">@link.Article.Title</span>
                                    <span class="pub-date">@link.Article.PublicationDate.ToString("MMMM dd, yyyy")</span>
                                </div>
                                <div class="pub-arrow">
                                    <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                                </div>
                            </a>
                        }
                    }
                    else
                    {
                        <div class="empty-state">
                            <svg viewBox="0 0 24 24" width="48" height="48" fill="none" stroke="currentColor" stroke-width="1" style="margin-bottom: 16px; opacity: 0.5;"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                            <br />
                            No articles published yet.
                        </div>
                    }
                </div>
            </div>

            <div class="profile-actions">
                <a asp-action="Index" class="btn-back">
                    <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
                    Back to Authors
                </a>

                @if (User.IsInRole("Admin"))
                {
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-edit-profile">
                        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
                        Edit Profile
                    </a>
                }
            </div>

        </div>
    </div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const stars = document.querySelectorAll('.star-btn');
            const confirmBtn = document.getElementById('confirmRatingBtn');
            const feedback = document.getElementById('ratingFeedback');
            const authorId = @Model.Id;
            let currentSelectedRating = 0;

            if(stars.length > 0) {
                // Плавне наведення
                stars.forEach(star => {
                    star.addEventListener('mouseenter', function() {
                        const hoverValue = this.getAttribute('data-value');
                        stars.forEach(s => {
                            if(parseInt(s.getAttribute('data-value')) <= parseInt(hoverValue)) s.classList.add('hover-active');
                            else s.classList.remove('hover-active');
                        });
                    });

                    // Коли курсор йде, повертаємо до зафіксованого стану
                    star.addEventListener('mouseleave', function() {
                        stars.forEach(s => {
                            s.classList.remove('hover-active');
                        });
                    });

                    // Фіксування оцінки по кліку
                    star.addEventListener('click', function() {
                        currentSelectedRating = this.getAttribute('data-value');

                        stars.forEach(s => {
                            if(parseInt(s.getAttribute('data-value')) <= parseInt(currentSelectedRating)) s.classList.add('active');
                            else s.classList.remove('active');
                        });

                        // Показуємо кнопку підтвердження
                        confirmBtn.style.display = 'inline-block';
                        feedback.style.display = 'none';
                        feedback.style.opacity = '0';
                    });
                });

                // Логіка відправки на сервер
                confirmBtn.addEventListener('click', function() {
                    confirmBtn.disabled = true;
                    confirmBtn.innerText = "Saving...";

                    fetch(`/Authors/Rate`, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({
                            authorId: authorId,
                            score: parseInt(currentSelectedRating)
                        })
                    })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            confirmBtn.style.display = 'none';
                            confirmBtn.disabled = false;
                            confirmBtn.innerText = "Confirm Rating";

                            feedback.style.display = 'block';
                            setTimeout(() => { feedback.style.opacity = '1'; }, 10);

                            const ratingPill = document.getElementById('ratingPill');
                            if(ratingPill) {
                                ratingPill.innerHTML = `<svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path></svg> ${data.newRating}`;
                            }
                        } else {
                            alert("Error: " + data.message);
                            confirmBtn.disabled = false;
                            confirmBtn.innerText = "Confirm Rating";
                        }
                    })
                    .catch(error => {
                        console.error('Fetch Error:', error);
                        alert("Error saving rating. Check console for details.");
                        confirmBtn.disabled = false;
                        confirmBtn.innerText = "Confirm Rating";
                    });
                });
            }
        });
    </script>
}